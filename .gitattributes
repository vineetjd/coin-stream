# Normalize line endings to LF in the repo so Spotless and builds behave
# identically on Windows, macOS, and the Linux CI runner.
* text=auto eol=lf

# Explicit LF for source/config (belt and suspenders)
*.java   text eol=lf
*.xml    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.properties text eol=lf
*.json   text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.md     text eol=lf
*.sh     text eol=lf
Dockerfile text eol=lf

# Binary assets — never normalize
*.png binary
*.jpg binary
*.svg binary
*.jar binary
*.gz  binary
